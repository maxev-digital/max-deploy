generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Opportunity {
  id                String   @id @default(cuid())
  company           String
  role              String
  stage             String   @default("inbox")
  salaryMin         Int?
  salaryMax         Int?
  totalCompMin      Int?
  totalCompMax      Int?
  fitScore          Int?
  fitScoreOverride  Int?
  classification    String?
  recommendedAction String?
  resumeVariant     String?
  applyUrl          String?
  coverLetterUrl    String?
  source            String?
  sourceCompanySlug String?
  jdText            String?
  analysisJson      Json?
  notes             String?
  lastActivity      DateTime?
  followUpDue       DateTime?
  workType          String?   // full_time | part_time | contract | freelance
  appliedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  contacts          Contact[]
  outreachLogs      OutreachLog[]
  offer             Offer?
}

model TargetCompany {
  id          String   @id @default(cuid())
  name        String
  website     String?
  industry    String?
  size        String?
  techStack   String[]
  atsType     String?
  atsSlug     String?
  warmth      String   @default("cold")
  notes       String?
  watchlist   Boolean  @default(true)
  lastPolled  DateTime?
  createdAt   DateTime @default(now())
  contacts    Contact[]
}

model Contact {
  id            String         @id @default(cuid())
  name          String
  email         String?
  linkedin      String?
  role          String?
  company       TargetCompany? @relation(fields: [companyId], references: [id])
  companyId     String?
  opportunity   Opportunity?   @relation(fields: [opportunityId], references: [id])
  opportunityId String?
  lastContact   DateTime?
  warmth        String         @default("cold")
  notes         String?
  createdAt     DateTime       @default(now())
}

model OutreachLog {
  id            String      @id @default(cuid())
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id])
  opportunityId String
  type          String
  direction     String
  subject       String?
  body          String?
  sentAt        DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  repliedAt     DateTime?
  followUpDue   DateTime?
  status        String      @default("draft")
}

model RssFeed {
  id                  String   @id @default(cuid())
  name                String
  url                 String   @unique
  source              String
  active              Boolean  @default(true)
  lastPolled          DateTime?
  lastItemDate        DateTime?
  lastError           String?
  consecutiveFailures Int      @default(0)
  createdAt           DateTime @default(now())
}

model FeedTemplate {
  id          String   @id @default(cuid())
  name        String
  url         String
  source      String
  category    String
  description String?
  createdAt   DateTime @default(now())
}

model Offer {
  id                   String      @id @default(cuid())
  opportunity          Opportunity @relation(fields: [opportunityId], references: [id])
  opportunityId        String      @unique
  offerDate            DateTime?
  expirationDate       DateTime?
  baseSalary           Int?
  signingBonus         Int?
  annualBonus          Int?
  equityShares         Int?
  equityType           String?
  strikePrice          Float?
  vestingSchedule      String?
  cliffMonths          Int?
  estimatedEquityValue Float?
  totalYearOneComp     Int?
  benefitsJson         Json?
  status               String      @default("pending")
  notes                String?
  createdAt            DateTime    @default(now())
}

model Contract {
  id                String     @id @default(cuid())
  client            String
  projectName       String
  rateType          String
  rate              Int
  hoursPerWeek      Int?
  totalValue        Int?
  startDate         DateTime?
  endDate           DateTime?
  autoRenew         Boolean    @default(false)
  renewalNoticeDays Int?
  status            String     @default("proposed")
  sowUrl            String?
  notes             String?
  createdAt         DateTime   @default(now())
  milestones        Milestone[]
  invoices          Invoice[]
  timeLogs          TimeLog[]
}

model Milestone {
  id         String    @id @default(cuid())
  contract   Contract  @relation(fields: [contractId], references: [id])
  contractId String
  name       String
  dueDate    DateTime?
  value      Int?
  status     String    @default("pending")
}

model Invoice {
  id              String    @id @default(cuid())
  invoiceNumber   String    @unique
  contract        Contract? @relation(fields: [contractId], references: [id])
  contractId      String?
  client          String
  lineItems       Json
  subtotal        Int
  taxRate         Float     @default(0)
  taxAmount       Int       @default(0)
  total           Int
  dueDate         DateTime?
  sentAt          DateTime?
  viewedAt        DateTime?
  paidAt          DateTime?
  paymentMethod   String?
  stripePaymentId String?
  status          String    @default("draft")
  notes           String?
  createdAt       DateTime  @default(now())
}

model Task {
  id          String   @id @default(cuid())
  title       String
  priority    String   @default("MEDIUM") // HIGH | MEDIUM | LOW
  status      String   @default("TODO")   // TODO | IN_PROGRESS | REVIEW | DONE
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  linkedType  String?  // opportunity | contract | company
  linkedId    String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tasks")
}

model EmailAccount {
  id           String    @id @default(cuid())
  label        String    @default("Main Inbox")
  email        String    @unique
  imapHost     String    @default("imap.hostinger.com")
  imapPort     Int       @default(993)
  imapUser     String
  imapPass     String
  smtpHost     String    @default("smtp.hostinger.com")
  smtpPort     Int       @default(465)
  smtpUser     String
  smtpPass     String
  fromName     String    @default("Will Austin")
  lastSyncAt   DateTime?
  lastUid      Int       @default(0)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  messages     EmailMessage[]

  @@map("email_accounts")
}

model EmailMessage {
  id            String       @id @default(cuid())
  accountId     String
  account       EmailAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  uid           Int          @default(0)
  messageId     String?      @unique
  folder        String       @default("INBOX")
  subject       String?
  fromEmail     String
  fromName      String?
  toRaw         String       @default("[]")
  ccRaw         String?
  bccRaw        String?
  bodyHtml      String?
  bodyText      String?
  snippet       String?
  isRead        Boolean      @default(false)
  isStarred     Boolean      @default(false)
  isSent        Boolean      @default(false)
  isDraft       Boolean      @default(false)
  hasAttachment Boolean      @default(false)
  attachments   Json?
  inReplyTo     String?
  threadId      String?
  receivedAt    DateTime
  createdAt     DateTime     @default(now())

  @@index([accountId])
  @@index([folder])
  @@index([receivedAt(sort: Desc)])
  @@map("email_messages")
}

model TimeLog {
  id          String   @id @default(cuid())
  contract    Contract @relation(fields: [contractId], references: [id])
  contractId  String
  date        DateTime
  hours       Float
  description String?
  invoiced    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model BriefingCache {
  id          String   @id @default(cuid())
  briefing    String
  vitals      Json
  generatedAt DateTime @default(now())
}

model PromptTemplate {
  id        String   @id @default("default")
  content   Json
  updatedAt DateTime @updatedAt @default(now())

  @@map("prompt_templates")
}

model UserProfile {
  id             String   @id @default(cuid())
  userId         String   @default("1") @unique
  name           String?
  email          String?
  targetTitle    String?
  targetTitles   String[]
  salaryFloor    Int?
  geoPref        String?
  workType       String?
  skills         String[]
  industries     String[]
  dealBreakers   String?
  profileSummary String?
  resumePrimary  String?
  resumeAlt      String?
  imapHost       String?
  imapPort       Int?
  imapUser       String?
  imapPassEnc    String?
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpPassEnc    String?
  fromName       String?
  onboardingDone Boolean  @default(false)
  onboardingStep Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_profiles")
}
