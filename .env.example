# Database
DATABASE_URL="postgresql://user:password@localhost:5432/max_deploy"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3200"
ADMIN_EMAIL="your@email.com"
ADMIN_PASSWORD_HASH="bcrypt-hash-of-your-password"

# Email sending (SMTP)
SMTP_HOST="smtp.yourhost.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM="opportunities@your-domain.com"

# Email receiving (IMAP)
IMAP_HOST="imap.yourhost.com"
IMAP_PORT="993"
IMAP_USER="your@email.com"
IMAP_PASS="your-imap-password"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# Stripe (invoicing - optional)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
